.page {
  position: relative;
  min-height: 100vh;
  padding: 52rpx 28rpx 40rpx;
  overflow: hidden;
}

.page-lock {
  height: 100vh;
}

.bg-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(24px);
  opacity: 0.7;
  pointer-events: none;
}

.orb-1 {
  width: 360rpx;
  height: 360rpx;
  top: -60rpx;
  right: -80rpx;
  background: rgba(52, 199, 89, 0.14);
}

.orb-2 {
  width: 440rpx;
  height: 440rpx;
  left: -160rpx;
  top: 480rpx;
  background: rgba(31, 122, 255, 0.12);
}

.glass {
  background: rgba(255, 255, 255, 0.74);
  backdrop-filter: blur(28rpx);
  border: 1px solid rgba(255, 255, 255, 0.6);
}

.shadow {
  box-shadow: 0 30rpx 60rpx rgba(17, 17, 17, 0.12);
}

.hero-card,
.menu-preview,
.editor-card,
.segment-row {
  border-radius: 36rpx;
}

.hero-card {
  position: relative;
  z-index: 2;
  padding: 36rpx 28rpx 32rpx;
  box-shadow: 0 30rpx 80rpx rgba(17, 17, 17, 0.08);
}

.nav-row,
.preview-head,
.row-between,
.editor-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.title-wrap {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.eyebrow {
  font-size: 24rpx;
  color: #8e8e93;
}

.title {
  font-size: 56rpx;
  line-height: 1.08;
  font-weight: 700;
}

.subtitle,
.preview-meta,
.card-hint {
  font-size: 24rpx;
  color: #6e6e73;
}

.icon-btn {
  min-width: 120rpx;
  height: 72rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: rgba(17, 17, 17, 0.06);
  display: flex;
  align-items: center;
  justify-content: center;
}

.icon-btn-text,
.ghost-btn,
.delete-btn,
.add-btn,
.segment-item text,
.toggle-pill text {
  font-size: 26rpx;
  font-weight: 600;
}

.wheel-zone {
  position: relative;
  width: 100%;
  display: flex;
  justify-content: center;
  padding: 34rpx 0 24rpx;
}

.pointer-wrap {
  position: absolute;
  top: 6rpx;
  z-index: 4;
}

.pointer {
  width: 0;
  height: 0;
  border-left: 24rpx solid transparent;
  border-right: 24rpx solid transparent;
  border-top: 42rpx solid #111111;
  filter: drop-shadow(0 8rpx 12rpx rgba(17, 17, 17, 0.18));
}

.wheel-shell {
  position: relative;
  width: 620rpx;
  height: 620rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.68);
  display: flex;
  align-items: center;
  justify-content: center;
}

.wheel-canvas {
  width: 620rpx;
  height: 620rpx;
  border-radius: 50%;
}

.wheel-center {
  position: absolute;
  width: 156rpx;
  height: 156rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  box-shadow: 0 12rpx 30rpx rgba(17, 17, 17, 0.12);
}

.wheel-center-title {
  font-size: 30rpx;
  font-weight: 700;
}

.wheel-center-sub {
  font-size: 20rpx;
  color: #8e8e93;
  margin-top: 4rpx;
}

.primary-btn {
  height: 96rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 700;
}

.primary-btn.disabled {
  opacity: 0.6;
}

.result-card {
  margin-top: 24rpx;
  padding: 26rpx 28rpx;
  border-radius: 28rpx;
  background: rgba(17, 17, 17, 0.04);
  opacity: 0.8;
}

.result-label {
  display: block;
  font-size: 22rpx;
  color: #8e8e93;
}

.result-value {
  display: block;
  margin-top: 10rpx;
  font-size: 42rpx;
  font-weight: 700;
}

.menu-preview {
  position: relative;
  z-index: 2;
  margin-top: 24rpx;
  padding: 28rpx;
}

.preview-title,
.card-label,
.editor-title {
  font-size: 30rpx;
  font-weight: 700;
}

.chip-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 20rpx;
}

.food-chip {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(17, 17, 17, 0.06);
  font-size: 24rpx;
}

.mask {
  position: fixed;
  inset: 0;
  background: rgba(17, 17, 17, 0.22);
  opacity: 0;
  pointer-events: none;
  transition: opacity 280ms ease;
  z-index: 8;
}

.mask.show {
  opacity: 1;
  pointer-events: auto;
}

.editor-panel {
  position: fixed;
  inset: 0;
  background: linear-gradient(180deg, #f9f9fb 0%, #f1f1f4 100%);
  z-index: 9;
  transform: translateX(100%);
  transition: transform 320ms cubic-bezier(0.22, 1, 0.36, 1);
  display: flex;
  flex-direction: column;
}

.editor-panel.show {
  transform: translateX(0);
}

.editor-nav {
  padding: 0 28rpx 18rpx;
  min-height: 88rpx;
}

.nav-back,
.nav-placeholder {
  width: 140rpx;
  display: flex;
  align-items: center;
}

.nav-back {
  gap: 6rpx;
}

.back-arrow {
  font-size: 48rpx;
  line-height: 1;
}

.back-text {
  font-size: 28rpx;
  font-weight: 600;
}

.segment-row {
  margin: 0 28rpx;
  padding: 10rpx;
  display: flex;
  gap: 10rpx;
}

.segment-item {
  flex: 1;
  height: 74rpx;
  border-radius: 26rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #6e6e73;
}

.segment-item.active {
  background: #111111;
  color: #ffffff;
}

.editor-content {
  flex: 1;
  overflow-y: auto;
  padding: 22rpx 28rpx 40rpx;
}

.editor-card {
  padding: 26rpx;
  margin-bottom: 22rpx;
}

.name-input,
.food-input {
  width: 100%;
  border-radius: 22rpx;
  background: rgba(17, 17, 17, 0.05);
  padding: 24rpx;
  font-size: 28rpx;
  margin-top: 16rpx;
}

.food-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.food-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.food-input {
  flex: 1;
  margin-top: 0;
}

.delete-btn {
  min-width: 108rpx;
  height: 88rpx;
  border-radius: 24rpx;
  background: rgba(255, 59, 48, 0.12);
  color: #ff3b30;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-btn,
.ghost-btn {
  height: 84rpx;
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-btn {
  margin-top: 18rpx;
  background: rgba(17, 17, 17, 0.06);
}

.ghost-btn {
  min-width: 154rpx;
  padding: 0 20rpx;
  background: #111111;
  color: #ffffff;
}

.compact-card {
  margin-bottom: 0;
}

.toggle-pill {
  padding: 14rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(17, 17, 17, 0.06);
  color: #6e6e73;
}

.toggle-pill.active {
  background: rgba(52, 199, 89, 0.14);
  color: #179d3f;
}
